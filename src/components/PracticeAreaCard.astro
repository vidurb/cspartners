---
interface Props {
	title: string;
	href: string;
	iconUrl: string;
}

const { title, href, iconUrl } = Astro.props;
---

<a
	href={href}
	class="group flex flex-col items-center text-center p-6 rounded-xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md hover:border-brand-gold/40 transition-all duration-200"
>
	<div class="mb-4 w-24 h-24 flex items-center justify-center">
		<img src={iconUrl} alt="" class="max-h-20 w-auto object-contain" width={96} height={96} loading="lazy" />
	</div>
	<h3 class="font-display text-lg font-semibold text-brand-navy group-hover:text-brand-gold transition-colors leading-snug"
	>
		{title}
	</h3>
</a>
