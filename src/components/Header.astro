---
import { Image } from 'astro:assets';
import logo from '../assets/brand/logo.png';
import HeaderLink from './HeaderLink.astro';
import type { SiteSettingsDoc } from '../lib/sanity/types';

interface Props {
	site: SiteSettingsDoc;
}

const { site } = Astro.props;
const navLinks = site.navLinks;
const homeAria = site.headerHomeAriaLabel ?? site.siteTitle;
const mobileHomeLabel = site.mobileMenuHomeLabel ?? site.siteTitle;
---

<header
	class="sticky top-0 z-50 border-b border-amber-900/10 bg-brand-cream/95 backdrop-blur-md shadow-sm"
>
	<div class="max-w-6xl mx-auto px-4 flex items-center justify-between gap-4 h-20 md:h-24">
		<a href="/" class="shrink-0 flex items-center gap-2" aria-label={homeAria}>
			<Image src={logo} alt="C&S Partners" class="h-10 md:h-12 w-auto" width={200} height={48} />
		</a>

		<nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
			{
				navLinks.map(({ href, label }) => (
					<HeaderLink
						href={href}
						class="px-3 py-2 text-sm font-medium text-brand-navy hover:text-brand-gold transition-colors rounded-md"
					>
						{label}
					</HeaderLink>
				))
			}
		</nav>

		<button
			type="button"
			id="mobile-menu-btn"
			class="lg:hidden p-2 rounded-md text-brand-navy border border-slate-300"
			aria-expanded="false"
			aria-controls="mobile-menu"
			aria-label="Open menu"
		>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
			</svg>
		</button>
	</div>

	<div
		id="mobile-menu"
		class="hidden lg:hidden border-t border-slate-200 bg-brand-cream px-4 py-4"
		role="navigation"
		aria-label="Mobile"
	>
		<div class="flex flex-col gap-1">
			<a href="/" class="px-3 py-3 text-brand-navy font-medium border-b border-slate-100">{mobileHomeLabel}</a>
			{
				navLinks.map(({ href, label }) => (
					<a href={href} class="px-3 py-3 text-brand-navy font-medium border-b border-slate-100 hover:text-brand-gold">
						{label}
					</a>
				))
			}
		</div>
	</div>
</header>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	if (btn && menu) {
		btn.addEventListener('click', () => {
			const open = menu.classList.toggle('hidden') === false;
			btn.setAttribute('aria-expanded', open ? 'true' : 'false');
		});
	}
</script>
