---
import { Image } from 'astro:assets';
import logo from '../assets/brand/logo.png';
import type { SiteSettingsDoc } from '../lib/sanity/types';

interface Props {
	site: SiteSettingsDoc;
}

const { site } = Astro.props;
const year = new Date().getFullYear();
const navLinks = site.navLinks;
const offices = site.offices;
const navHeading = site.footerNavigateHeading ?? 'Navigate';
const officesHeading = site.footerOfficesHeading ?? 'Offices';
const contactHeading = site.footerContactHeading ?? 'Contact';
const tagline = site.footerTagline ?? `${site.siteTitle} — New Delhi & Mumbai.`;
---

<footer class="bg-brand-navy text-slate-200 mt-auto">
	<div class="max-w-6xl mx-auto px-4 py-14 grid gap-10 md:grid-cols-2 lg:grid-cols-4">
		<div>
			<Image src={logo} alt="" class="h-10 w-auto mb-4 brightness-0 invert opacity-90" width={180} height={44} />
			<p class="text-sm text-slate-400 leading-relaxed">{tagline}</p>
		</div>
		<div>
			<h3 class="font-display text-lg font-semibold text-white mb-3">{navHeading}</h3>
			<ul class="space-y-2 text-sm">
				<li><a href="/" class="hover:text-brand-gold-light transition-colors">{site.siteTitle}</a></li>
				{
					navLinks.map(({ href, label }) => (
						<li>
							<a href={href} class="hover:text-brand-gold-light transition-colors">
								{label}
							</a>
						</li>
					))
				}
			</ul>
		</div>
		<div>
			<h3 class="font-display text-lg font-semibold text-white mb-3">{officesHeading}</h3>
			<div class="space-y-4 text-sm text-slate-300">
				{
					offices.map((office) => (
						<div>
							<p class="font-medium text-white">{office.label}</p>
							<p>{office.street}</p>
							<p>{office.city}</p>
							<p class="mt-1">
								<a href={`tel:${office.phone.replace(/\s/g, '')}`} class="hover:text-brand-gold-light">
									{office.phone}
								</a>
							</p>
						</div>
					))
				}
			</div>
		</div>
		<div>
			<h3 class="font-display text-lg font-semibold text-white mb-3">{contactHeading}</h3>
			<p class="text-sm text-slate-300">
				<a href={`mailto:${site.contactEmail}`} class="hover:text-brand-gold-light break-all">
					{site.contactEmail}
				</a>
			</p>
		</div>
	</div>
	<div class="border-t border-white/10">
		<div class="max-w-6xl mx-auto px-4 py-6 text-center text-xs text-slate-500">
			&copy; {year} {site.siteTitle}. All rights reserved.
		</div>
	</div>
</footer>
