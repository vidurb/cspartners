---
import { Image } from 'astro:assets';
import logo from '../assets/brand/logo.png';
import { CONTACT, NAV_LINKS, SITE_TITLE } from '../consts';

const year = new Date().getFullYear();
---

<footer class="bg-brand-navy text-slate-200 mt-auto">
	<div class="max-w-6xl mx-auto px-4 py-14 grid gap-10 md:grid-cols-2 lg:grid-cols-4">
		<div>
			<Image src={logo} alt="" class="h-10 w-auto mb-4 brightness-0 invert opacity-90" width={180} height={44} />
			<p class="text-sm text-slate-400 leading-relaxed">{SITE_TITLE} — New Delhi & Mumbai.</p>
		</div>
		<div>
			<h3 class="font-display text-lg font-semibold text-white mb-3">Navigate</h3>
			<ul class="space-y-2 text-sm">
				<li><a href="/" class="hover:text-brand-gold-light transition-colors">C&S Partners</a></li>
				{
					NAV_LINKS.map(({ href, label }) => (
						<li>
							<a href={href} class="hover:text-brand-gold-light transition-colors">
								{label}
							</a>
						</li>
					))
				}
			</ul>
		</div>
		<div>
			<h3 class="font-display text-lg font-semibold text-white mb-3">Offices</h3>
			<div class="space-y-4 text-sm text-slate-300">
				<div>
					<p class="font-medium text-white">{CONTACT.delhi.label}</p>
					<p>{CONTACT.delhi.street}</p>
					<p>{CONTACT.delhi.city}</p>
					<p class="mt-1">
						<a href={`tel:${CONTACT.delhi.phone.replace(/\s/g, '')}`} class="hover:text-brand-gold-light">
							{CONTACT.delhi.phone}
						</a>
					</p>
				</div>
				<div>
					<p class="font-medium text-white">{CONTACT.mumbai.label}</p>
					<p>{CONTACT.mumbai.street}</p>
					<p>{CONTACT.mumbai.city}</p>
					<p class="mt-1">
						<a href={`tel:${CONTACT.mumbai.phone.replace(/\s/g, '')}`} class="hover:text-brand-gold-light">
							{CONTACT.mumbai.phone}
						</a>
					</p>
				</div>
			</div>
		</div>
		<div>
			<h3 class="font-display text-lg font-semibold text-white mb-3">Contact</h3>
			<p class="text-sm text-slate-300">
				<a href={`mailto:${CONTACT.email}`} class="hover:text-brand-gold-light break-all">
					{CONTACT.email}
				</a>
			</p>
		</div>
	</div>
	<div class="border-t border-white/10">
		<div class="max-w-6xl mx-auto px-4 py-6 text-center text-xs text-slate-500">
			&copy; {year} {SITE_TITLE}. All rights reserved.
		</div>
	</div>
</footer>
