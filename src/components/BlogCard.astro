---
import FormattedDate from './FormattedDate.astro';

interface Props {
	title: string;
	description: string;
	href: string;
	pubDate: Date;
	heroImageUrl?: string;
	readMoreLabel?: string;
}

const { title, description, href, pubDate, heroImageUrl, readMoreLabel = 'Read more' } = Astro.props;
---

<article
	class="flex flex-col bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-lg hover:border-brand-gold/30 transition-all"
>
	<a href={href} class="block aspect-[2/1] overflow-hidden bg-slate-100">
		{
			heroImageUrl ? (
				<img
					src={heroImageUrl}
					alt=""
					class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
					width={800}
					height={400}
					loading="lazy"
				/>
			) : (
				<div class="w-full h-full bg-gradient-to-br from-brand-navy to-slate-800" />
			)
		}
	</a>
	<div class="p-5 flex flex-col flex-1">
		<time class="text-xs uppercase tracking-wide text-brand-gold font-semibold">
			<FormattedDate date={pubDate} />
		</time>
		<h3 class="font-display text-xl font-semibold text-brand-navy mt-2 mb-2 leading-snug">
			<a href={href} class="hover:text-brand-gold transition-colors">
				{title}
			</a>
		</h3>
		<p class="text-slate-600 text-sm leading-relaxed flex-1 line-clamp-3">{description}</p>
		<a href={href} class="mt-4 text-sm font-semibold text-brand-gold hover:text-brand-gold-light inline-flex items-center gap-1">
			{readMoreLabel}
			<span aria-hidden="true">→</span>
		</a>
	</div>
</article>
