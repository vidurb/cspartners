---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '').replace(/\/$/, '') || '/';
const hrefPath = String(href).replace(/\/$/, '') || '/';
let isActive = false;
if (hrefPath === '/') {
	isActive = pathname === '/';
} else {
	isActive = pathname === hrefPath || pathname.startsWith(hrefPath + '/');
}
---

<a
	href={href}
	class:list={[className, isActive && 'text-brand-gold font-semibold']}
	aria-current={isActive ? 'page' : undefined}
	{...props}
>
	<slot />
</a>
