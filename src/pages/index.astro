---
import { Image } from 'astro:assets';
import { loadQuery } from '../lib/sanity/loadQuery';
import BlogCard from '../components/BlogCard.astro';
import ContactForm from '../components/ContactForm.astro';
import PortableTextBody from '../components/PortableTextBody.astro';
import PracticeAreaCard from '../components/PracticeAreaCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import groupPhoto from '../assets/blog/group-photo.jpg';
import {
	blogPostsListQuery,
	homePageQuery,
	practiceAreasListQuery,
	siteSettingsCompactQuery,
	teamMembersListQuery,
} from '../lib/sanity/queries';
import type { BlogPostListItem, HomePageDoc, PracticeAreaListItem, SiteSettingsDoc, TeamMemberDoc } from '../lib/sanity/types';
import { resolveImageUrl } from '../lib/sanity/imageUrl';
import { mergeHomePage, mergeSiteSettings } from '../lib/sanity/mergeContent';
import {
	isHomepageTeamCarouselRole,
	sortTeamMembersForHomeCarousel,
} from '../lib/sanity/teamMemberSort';

const [siteRaw, homeRaw, practiceRaw, posts, teamMembersRaw] = await Promise.all([
	loadQuery<Partial<SiteSettingsDoc> | null>(siteSettingsCompactQuery),
	loadQuery<Partial<HomePageDoc> | null>(homePageQuery),
	loadQuery<PracticeAreaListItem[]>(practiceAreasListQuery),
	loadQuery<BlogPostListItem[]>(blogPostsListQuery),
	loadQuery<TeamMemberDoc[]>(teamMembersListQuery),
]);

const site = mergeSiteSettings(siteRaw);
const home = mergeHomePage(homeRaw);

const practiceAreas = practiceRaw.sort((a, b) => a.order - b.order);
const sortedPosts = posts.sort((a, b) => new Date(b.publishedAt).valueOf() - new Date(a.publishedAt).valueOf());
const teamPreview = teamMembersRaw
	.filter((m) => isHomepageTeamCarouselRole(m.role))
	.sort(sortTeamMembersForHomeCarousel)
	.map((m) => ({
		name: m.name,
		role: m.role,
		photoUrl: resolveImageUrl(m.photo, 400) ?? '',
	}));

const awardRecognitions = [
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/03/Untitled-1080-x-1080-px-150x150.png',
		alt: 'C&S Partners award recognition',
	},
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/03/1-1-150x150.png',
		alt: 'C&S Partners award recognition',
	},
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/03/3-2-150x150.png',
		alt: 'C&S Partners award recognition',
	},
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/03/2-1-150x150.png',
		alt: 'C&S Partners award recognition',
	},
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/03/1-3-150x150.png',
		alt: 'C&S Partners award recognition',
	},
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/03/3-1-150x150.png',
		alt: 'C&S Partners award recognition',
	},
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/03/benchmark-litigation-1024x576-1-150x150.jpg',
		alt: 'Benchmark Litigation award recognition for C&S Partners',
	},
];

const founderImgUrl = resolveImageUrl(home.founderImage ?? null, 1024);
const readMore = site.blogReadMoreLabel ?? 'Read more';
---

<BaseLayout title={site.siteTitle} description={site.siteDescription ?? ''}>
	<section
		class="relative bg-gradient-to-br from-brand-navy via-brand-navy-light to-slate-900 text-white px-4 py-20 md:py-28 overflow-hidden"
	>
		<div class="absolute inset-0 opacity-10 pointer-events-none bg-[radial-gradient(circle_at_30%_20%,#b8860b,transparent_50%)]"></div>
		<div class="max-w-5xl mx-auto text-center relative">
			<h1 class="font-display text-4xl md:text-6xl font-semibold tracking-tight mb-6">{home.heroTitle}</h1>
			<p class="text-lg md:text-xl text-slate-200 max-w-2xl mx-auto mb-8 text-justify">
				{home.heroSubtitle}
			</p>
			<a
				href={home.heroCtaHref ?? '/contact-career'}
				class="inline-flex items-center justify-center rounded-md bg-brand-gold px-8 py-3 font-semibold text-brand-navy hover:bg-brand-gold-light transition-colors"
			>
				{home.heroCtaLabel}
			</a>
		</div>
	</section>

	<section class="py-16 px-4 bg-white">
		<div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
			<div>
				<h2 class="font-display text-3xl md:text-4xl font-semibold text-brand-navy mb-6">{home.founderHeading}</h2>
				<div class="space-y-4 text-slate-700 leading-relaxed">
					<PortableTextBody value={home.founderBody} />
					{home.founderSignature && <p class="font-medium text-brand-navy text-justify">{home.founderSignature}</p>}
					<a
						href={home.founderCtaHref ?? '/about-us'}
						class="inline-block mt-4 text-brand-gold font-semibold hover:text-brand-gold-light"
					>
						{home.founderCtaLabel}
					</a>
				</div>
			</div>
			<div class="rounded-xl overflow-hidden shadow-lg border border-slate-200">
				{
					founderImgUrl ? (
						<img src={founderImgUrl} alt="" class="w-full h-auto object-cover" width={1024} height={750} loading="lazy" />
					) : (
						<Image src={groupPhoto} alt="" class="w-full h-auto object-cover" width={1024} height={750} />
					)
				}
			</div>
		</div>
	</section>

	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-6xl mx-auto">
			<h2 class="font-display text-3xl md:text-4xl font-semibold text-brand-navy text-center mb-4">{home.practiceAreasHeading}</h2>
			<p class="text-slate-600 max-w-2xl mx-auto mb-12 text-justify">
				{home.practiceAreasIntro}
			</p>
			<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
				{
					practiceAreas.map((p) => (
						<PracticeAreaCard
							title={p.title}
							href={`/practice-area/${p.slug}/`}
							iconUrl={resolveImageUrl(p.icon, 128) ?? ''}
						/>
					))
				}
			</div>
			<div class="text-center mt-10">
				<a
					href="/practice-area"
					class="inline-flex font-semibold text-brand-gold hover:text-brand-gold-light"
				>
					{home.practiceAreasViewAllLabel}
				</a>
			</div>
		</div>
	</section>

	<section class="py-16 px-4 bg-white">
		<div class="max-w-6xl mx-auto">
			<h2 class="font-display text-3xl md:text-4xl font-semibold text-brand-navy text-center mb-12">{home.teamHeading}</h2>
			<div class="-mx-4 px-4 md:mx-0 md:px-0">
				<div
					class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 [scrollbar-width:thin] md:[scrollbar-gutter:stable]"
					role="region"
					aria-label="Team members"
				>
					{
						teamPreview.map((m) => (
							<a
								href="/our-team"
								class="group text-center shrink-0 w-[45%] min-w-[10rem] max-w-[12rem] sm:w-[40%] md:w-[calc(25%-1.125rem)] snap-start"
							>
								<div class="aspect-square rounded-full overflow-hidden mb-3 ring-2 ring-transparent group-hover:ring-brand-gold/40 transition-all">
									{m.photoUrl ? (
										<img
											src={m.photoUrl}
											alt=""
											class="w-full h-full object-cover"
											width="200"
											height="200"
											loading="lazy"
										/>
									) : (
										<div class="w-full h-full bg-slate-200" />
									)}
								</div>
								<p class="font-semibold text-brand-navy text-sm group-hover:text-brand-gold">{m.name}</p>
								<p class="text-xs text-slate-600">{m.role}</p>
							</a>
						))
					}
				</div>
			</div>
			<p class="text-center mt-10">
				<a href="/our-team" class="font-semibold text-brand-gold hover:text-brand-gold-light">{home.teamMeetFullLabel}</a>
			</p>
		</div>
	</section>

	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-6xl mx-auto">
			<h2 class="font-display text-3xl md:text-4xl font-semibold text-brand-navy text-center mb-4">Awards &amp; Recognitions</h2>
			<p class="text-slate-600 max-w-2xl mx-auto mb-12 text-justify">
				Recognitions received by the firm across leading legal directories and industry publications.
			</p>
			<div class="-mx-4 px-4 md:mx-0 md:px-0">
				<div
					class="flex gap-6 overflow-x-auto overflow-y-hidden scroll-smooth snap-x snap-mandatory pb-4 scroll-px-4 [scrollbar-width:thin] md:[scrollbar-gutter:stable] touch-pan-x"
					role="region"
					aria-roledescription="carousel"
					aria-label="Awards and recognitions"
				>
					{
						awardRecognitions.map((award) => (
							<div
								class="shrink-0 w-[42%] min-w-[9rem] max-w-[11rem] sm:w-[28%] md:w-[calc(14.285%-1.286rem)] snap-start"
								role="group"
								aria-roledescription="slide"
								aria-label={award.alt}
							>
								<div class="aspect-square rounded-xl border border-slate-200 bg-white p-4 shadow-sm flex items-center justify-center">
									<img
										src={award.src}
										alt={award.alt}
										class="max-h-full max-w-full object-contain"
										width="150"
										height="150"
										loading="lazy"
									/>
								</div>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-6xl mx-auto">
			<h2 class="font-display text-3xl md:text-4xl font-semibold text-brand-navy text-center mb-12">{home.blogsHeading}</h2>
			<div class="-mx-4 px-4 md:mx-0 md:px-0">
				<div
					class="flex gap-8 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 [scrollbar-width:thin] md:[scrollbar-gutter:stable]"
					role="region"
					aria-label="Blog posts"
				>
					{
						sortedPosts.map((post) => (
							<div class="shrink-0 w-[min(100%,22rem)] md:w-[min(100%,20rem)] lg:w-[calc(33.333%-1.334rem)] snap-start min-w-[16rem]">
								<BlogCard
									title={post.title}
									description={post.description}
									href={`/blog/${post.slug}/`}
									pubDate={new Date(post.publishedAt)}
									heroImageUrl={resolveImageUrl(post.heroImage, 800)}
									readMoreLabel={readMore}
								/>
							</div>
						))
					}
				</div>
			</div>
			<p class="text-center mt-10">
				<a href="/blog" class="font-semibold text-brand-gold hover:text-brand-gold-light">{home.blogsAllArticlesLabel}</a>
			</p>
		</div>
	</section>

	<section class="py-16 px-4 bg-brand-navy text-slate-200">
		<div class="max-w-3xl mx-auto text-center">
			<h2 class="font-display text-3xl font-semibold text-white mb-8">{home.contactSectionHeading}</h2>
			<ContactForm idSuffix="home" variant="dark" />
		</div>
	</section>
</BaseLayout>
