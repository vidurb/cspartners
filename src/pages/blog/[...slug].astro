---
import { sanityClient } from 'sanity:client';
import BlogPost from '../../layouts/BlogPost.astro';
import { blogPostBySlugQuery, blogPostsListQuery, siteSettingsCompactQuery } from '../../lib/sanity/queries';
import type { BlogPostDetail, BlogPostListItem, SiteSettingsDoc } from '../../lib/sanity/types';
import { resolveImageUrl } from '../../lib/sanity/imageUrl';
import { mergeSiteSettings } from '../../lib/sanity/mergeContent';

export async function getStaticPaths() {
	const posts = await sanityClient.fetch<BlogPostListItem[]>(blogPostsListQuery);
	return posts.map((p) => ({
		params: { slug: p.slug },
	}));
}

const slug = Astro.params.slug;
if (!slug || Array.isArray(slug)) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const [siteRaw, post] = await Promise.all([
	sanityClient.fetch<Partial<SiteSettingsDoc> | null>(siteSettingsCompactQuery),
	sanityClient.fetch<BlogPostDetail | null>(blogPostBySlugQuery, { slug }),
]);

const site = mergeSiteSettings(siteRaw);

if (!post) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const heroImageUrl = resolveImageUrl(post.heroImage, 1200);
const author = post.author?.trim() || site.blogAuthorFallback || site.siteTitle;
---

<BlogPost
	title={post.title}
	description={post.description}
	pubDate={new Date(post.publishedAt)}
	updatedDate={post.updatedAt ? new Date(post.updatedAt) : undefined}
	author={author}
	heroImageUrl={heroImageUrl}
	body={post.body}
	siteTitle={site.siteTitle}
/>
