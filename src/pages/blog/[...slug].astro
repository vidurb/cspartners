---
import { loadQuery } from '../../lib/sanity/loadQuery';
import BlogPost from '../../layouts/BlogPost.astro';
import { blogPostBySlugQuery, siteSettingsCompactQuery } from '../../lib/sanity/queries';
import type { BlogPostDetail, SiteSettingsDoc } from '../../lib/sanity/types';
import { resolveImageUrl } from '../../lib/sanity/imageUrl';
import { singletonDataAttribute } from '../../lib/sanity/dataAttributes';
import { mergeSiteSettings } from '../../lib/sanity/mergeContent';

const slug = Astro.params.slug;
if (!slug || Array.isArray(slug)) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const [siteRaw, post] = await Promise.all([
	loadQuery<Partial<SiteSettingsDoc> | null>(siteSettingsCompactQuery),
	loadQuery<BlogPostDetail | null>(blogPostBySlugQuery, { slug }),
]);

const site = mergeSiteSettings(siteRaw);

if (!post) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const heroImageUrl = resolveImageUrl(post.heroImage, 1200);
const author = post.author?.trim() || site.blogAuthorFallback || site.siteTitle;
const authorDataSanity = post.author?.trim()
	? undefined
	: singletonDataAttribute('siteSettings', 'blogAuthorFallback', site._id ?? 'siteSettings');
---

<BlogPost
	title={post.title}
	description={post.description}
	pubDate={new Date(post.publishedAt)}
	updatedDate={post.updatedAt ? new Date(post.updatedAt) : undefined}
	author={author}
	heroImageUrl={heroImageUrl}
	body={post.body}
	siteTitle={site.siteTitle}
	authorDataSanity={authorDataSanity}
/>
