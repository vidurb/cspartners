---
import { sanityClient } from 'sanity:client';
import BlogPost from '../../layouts/BlogPost.astro';
import { blogPostBySlugQuery, blogPostsListQuery } from '../../lib/sanity/queries';
import type { BlogPostDetail, BlogPostListItem } from '../../lib/sanity/types';
import { resolveImageUrl } from '../../lib/sanity/imageUrl';

export async function getStaticPaths() {
	const posts = await sanityClient.fetch<BlogPostListItem[]>(blogPostsListQuery);
	return posts.map((p) => ({
		params: { slug: p.slug },
	}));
}

const slug = Astro.params.slug;
if (!slug || Array.isArray(slug)) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const post = await sanityClient.fetch<BlogPostDetail | null>(blogPostBySlugQuery, { slug });

if (!post) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const heroImageUrl = resolveImageUrl(post.heroImage, 1200);
---

<BlogPost
	title={post.title}
	description={post.description}
	pubDate={new Date(post.publishedAt)}
	updatedDate={post.updatedAt ? new Date(post.updatedAt) : undefined}
	author={post.author ?? 'C&S Partners'}
	heroImageUrl={heroImageUrl}
	body={post.body}
/>
