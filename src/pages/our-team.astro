---
import { sanityClient } from 'sanity:client';
import ContactForm from '../components/ContactForm.astro';
import Hero from '../components/Hero.astro';
import TeamMember from '../components/TeamMember.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { teamMembersListQuery } from '../lib/sanity/queries';
import type { TeamMemberDoc } from '../lib/sanity/types';
import { resolveImageUrl } from '../lib/sanity/imageUrl';

const teamMembersRaw = await sanityClient.fetch<TeamMemberDoc[]>(teamMembersListQuery);
const teamMembers = teamMembersRaw.map((m) => ({
	name: m.name,
	role: m.role,
	photoUrl: resolveImageUrl(m.photo, 400) ?? '',
	profilePdf: m.profilePdf,
}));
---

<BaseLayout title={`Our Team — ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<Hero title="Our Team" variant="dark" />
	<div class="max-w-6xl mx-auto px-4 py-16">
		<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
			{teamMembers.map((m) => <TeamMember member={m} />)}
		</div>
	</div>
	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-3xl mx-auto text-center">
			<h2 class="font-display text-3xl font-semibold text-brand-navy mb-8">Contact Us</h2>
			<ContactForm idSuffix="team" />
		</div>
	</section>
</BaseLayout>
