---
import { sanityClient } from 'sanity:client';
import ContactForm from '../../components/ContactForm.astro';
import Hero from '../../components/Hero.astro';
import PracticeAreaCard from '../../components/PracticeAreaCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { practiceAreasListQuery } from '../../lib/sanity/queries';
import type { PracticeAreaListItem } from '../../lib/sanity/types';
import { resolveImageUrl } from '../../lib/sanity/imageUrl';

const practiceRaw = await sanityClient.fetch<PracticeAreaListItem[]>(practiceAreasListQuery);
const practiceAreas = practiceRaw.sort((a, b) => a.order - b.order);
---

<BaseLayout title={`Practice Areas — ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<Hero title="Our Practice Areas" variant="dark" />
	<div class="max-w-6xl mx-auto px-4 py-16">
		<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
			{
				practiceAreas.map((p) => (
					<PracticeAreaCard
						title={p.title}
						href={`/practice-area/${p.slug}/`}
						iconUrl={resolveImageUrl(p.icon, 128) ?? ''}
					/>
				))
			}
		</div>
	</div>
	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-3xl mx-auto text-center">
			<h2 class="font-display text-3xl font-semibold text-brand-navy mb-8">Contact Us</h2>
			<ContactForm idSuffix="practice-hub" />
		</div>
	</section>
</BaseLayout>
