---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import Hero from '../../components/Hero.astro';
import PortableTextBody from '../../components/PortableTextBody.astro';
import { contactFormSettingsQuery, jobPageBySlugQuery, jobPagesListQuery, siteSettingsCompactQuery } from '../../lib/sanity/queries';
import type { ContactFormSettingsDoc, JobPageDetail, JobPageListItem, SiteSettingsDoc } from '../../lib/sanity/types';
import { sanityClient } from 'sanity:client';
import { mergeContactFormSettings, mergeSiteSettings } from '../../lib/sanity/mergeContent';
import { DEFAULT_INTERNSHIP_JOB } from '../../lib/sanity/fallbacks';

export async function getStaticPaths() {
	const jobs = await sanityClient.fetch<JobPageListItem[]>(jobPagesListQuery);
	const slugSet = new Set(jobs.map((j) => j.slug));
	slugSet.add('internship');
	return [...slugSet].map((s) => ({ params: { slug: s } }));
}

const slug = Astro.params.slug;
if (!slug || Array.isArray(slug)) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const [siteRaw, jobRaw, contactFormRaw] = await Promise.all([
	sanityClient.fetch<Partial<SiteSettingsDoc> | null>(siteSettingsCompactQuery),
	sanityClient.fetch<JobPageDetail | null>(jobPageBySlugQuery, { slug }),
	sanityClient.fetch<ContactFormSettingsDoc | null>(contactFormSettingsQuery),
]);

const site = mergeSiteSettings(siteRaw);
const contactForm = mergeContactFormSettings(contactFormRaw);

let job: JobPageDetail;
if (jobRaw) {
	job = {
		...jobRaw,
		body: jobRaw.body ?? [],
		howToApplyBody: jobRaw.howToApplyBody ?? [],
	};
} else if (slug === 'internship') {
	job = DEFAULT_INTERNSHIP_JOB;
} else {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}
---

<BaseLayout title={`${job.title} — ${site.siteTitle}`} description={job.description ?? ''}>
	<Hero title={job.title} variant="dark" />
	<div class="max-w-3xl mx-auto px-4 py-16 text-slate-700 leading-relaxed space-y-6">
		<PortableTextBody value={job.body} />
		{
			(job.howToApplyHeading || job.howToApplyBody?.length) && (
				<>
					{job.howToApplyHeading && (
						<h2 class="font-display text-xl font-semibold text-brand-navy pt-4">{job.howToApplyHeading}</h2>
					)}
					<PortableTextBody value={job.howToApplyBody} />
				</>
			)
		}
	</div>
	{
		slug === 'internship' && (
			<section class="py-16 px-4 bg-brand-paper">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="font-display text-3xl font-semibold text-brand-navy mb-8">Internship inquiries</h2>
					<ContactForm idSuffix="internship" settings={contactForm} source="internship" />
				</div>
			</section>
		)
	}
</BaseLayout>
