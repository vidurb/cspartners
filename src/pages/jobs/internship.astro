---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { SITE_TITLE } from '../../consts';
---

<BaseLayout
	title={`Internship — ${SITE_TITLE}`}
	description="Internship opportunities at C&S Partners — Delhi & Mumbai."
>
	<Hero title="Internship" variant="dark" />
	<div class="max-w-3xl mx-auto px-4 py-16 text-slate-700 leading-relaxed space-y-6">
		<p>
			C&S Partners offers internship opportunities for motivated law students and recent graduates who want exposure to
			disputes, regulatory matters, transactions, and firm life in a collaborative environment.
		</p>
		<p>
			We emphasize research, drafting, and clear thinking. Interns work alongside partners and associates on live matters
			where appropriate, with feedback and mentorship built into how we operate.
		</p>
		<h2 class="font-display text-xl font-semibold text-brand-navy pt-4">How to apply</h2>
		<p>
			Applications were previously submitted through the firm’s website portal. This static rebuild preserves the internship
			information page; to apply, please email <a href="mailto:contact@cspartners.in" class="text-brand-gold font-semibold"
				>contact@cspartners.in</a
			> with your CV and a brief cover note, or use the contact form on the <a href="/contact-career" class="text-brand-gold font-semibold"
				>Contact</a
			> page.
		</p>
	</div>
</BaseLayout>
