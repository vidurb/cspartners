---
import ContactForm from '../components/ContactForm.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<BaseLayout title={`Contact Us & Careers — ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<Hero title="Let’s Connect" subtitle="New Delhi & Mumbai" variant="dark" />

	<section class="max-w-6xl mx-auto px-4 py-16 grid md:grid-cols-2 gap-12">
		<div class="space-y-8">
			<div>
				<h2 class="font-display text-xl font-semibold text-brand-navy mb-2">{CONTACT.delhi.label}</h2>
				<p class="text-slate-700">{CONTACT.delhi.street}</p>
				<p class="text-slate-700">{CONTACT.delhi.city}</p>
				<p class="mt-2">
					<a href={`tel:${CONTACT.delhi.phone.replace(/\s/g, '')}`} class="text-brand-gold font-semibold hover:underline">
						{CONTACT.delhi.phone}
					</a>
				</p>
			</div>
			<div>
				<h2 class="font-display text-xl font-semibold text-brand-navy mb-2">{CONTACT.mumbai.label}</h2>
				<p class="text-slate-700">{CONTACT.mumbai.street}</p>
				<p class="text-slate-700">{CONTACT.mumbai.city}</p>
				<p class="mt-2">
					<a
						href={`tel:${CONTACT.mumbai.phone.replace(/\s/g, '')}`}
						class="text-brand-gold font-semibold hover:underline"
					>
						{CONTACT.mumbai.phone}
					</a>
				</p>
			</div>
			<div>
				<h2 class="font-display text-xl font-semibold text-brand-navy mb-2">Email</h2>
				<a href={`mailto:${CONTACT.email}`} class="text-brand-gold font-semibold hover:underline break-all">
					{CONTACT.email}
				</a>
			</div>
		</div>
		<div class="space-y-6">
			<div class="rounded-xl overflow-hidden border border-slate-200 shadow-sm aspect-video">
				<iframe
					title="C&S Partners New Delhi office"
					class="w-full h-full min-h-[240px]"
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					src="https://www.google.com/maps?q=C-2%2F6%2C%20Sri%20Aurobindo%20Marg%20Safdarjung%20Development%20Area%20New%20Delhi%20110016&output=embed"
				></iframe>
			</div>
			<div class="rounded-xl overflow-hidden border border-slate-200 shadow-sm aspect-video">
				<iframe
					title="C&S Partners Mumbai office"
					class="w-full h-full min-h-[240px]"
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					src="https://www.google.com/maps?q=203%20Madhava%20Premises%20Bandra%20Kurla%20Complex%20Mumbai&output=embed"
				></iframe>
			</div>
		</div>
	</section>

	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-3xl mx-auto text-center mb-12">
			<h2 class="font-display text-3xl font-semibold text-brand-navy mb-8">Contact Us</h2>
			<ContactForm idSuffix="contact" />
		</div>
	</section>

	<section class="max-w-3xl mx-auto px-4 pb-20">
		<h2 class="font-display text-2xl font-semibold text-brand-navy mb-4">Internships</h2>
		<p class="text-slate-700 leading-relaxed mb-6">
			We value clarity, drafting, and strategic problem-solving. Our culture is collaborative, with an open-door approach and mentorship for those early in their careers. If you are interested in an internship, learn more and apply through our
			internship page.
		</p>
		<a
			href="/jobs/internship"
			class="inline-flex rounded-md bg-brand-gold px-6 py-3 font-semibold text-brand-navy hover:bg-brand-gold-light"
		>
			Apply here
		</a>
	</section>
</BaseLayout>
