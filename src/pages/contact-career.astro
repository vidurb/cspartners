---
import ContactForm from '../components/ContactForm.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactPageQuery, siteSettingsCompactQuery } from '../lib/sanity/queries';
import type { ContactPageDoc, SiteSettingsDoc } from '../lib/sanity/types';
import { loadQuery } from '../lib/sanity/loadQuery';
import { keyedArrayFieldPath, singletonDataAttribute } from '../lib/sanity/dataAttributes';
import { mergeContactPage, mergeSiteSettings } from '../lib/sanity/mergeContent';

const [siteRaw, contactPageRaw] = await Promise.all([
	loadQuery<Partial<SiteSettingsDoc> | null>(siteSettingsCompactQuery),
	loadQuery<Partial<ContactPageDoc> | null>(contactPageQuery),
]);

const site = mergeSiteSettings(siteRaw);
const contactPage = mergeContactPage(contactPageRaw);
const offices = site.offices;
const siteId = site._id ?? 'siteSettings';
const contactPageId = contactPage._id ?? 'contactPage';
const siteField = (path: string) => singletonDataAttribute('siteSettings', path, siteId);
const contactPageField = (path: string) => singletonDataAttribute('contactPage', path, contactPageId);
---

<BaseLayout title={`Contact Us & Careers — ${site.siteTitle}`} description={site.siteDescription ?? ''}>
	<Hero
		title={contactPage.heroTitle ?? "Let's Connect"}
		subtitle={contactPage.heroSubtitle ?? undefined}
		variant="dark"
		titleDataSanity={contactPageField('heroTitle')}
		subtitleDataSanity={contactPageField('heroSubtitle')}
	/>

	<section class="max-w-6xl mx-auto px-4 py-16 grid md:grid-cols-2 gap-12">
		<div class="space-y-8">
			{
				offices.map((office) => (
					<div>
						<h2
							class="font-display text-xl font-semibold text-brand-navy mb-2"
							data-sanity={siteField(keyedArrayFieldPath('offices', office._key, 'label') ?? 'offices')}
						>{office.label}</h2>
						<p
							class="text-slate-700 text-justify"
							data-sanity={siteField(keyedArrayFieldPath('offices', office._key, 'street') ?? 'offices')}
						>{office.street}</p>
						<p
							class="text-slate-700 text-justify"
							data-sanity={siteField(keyedArrayFieldPath('offices', office._key, 'city') ?? 'offices')}
						>{office.city}</p>
						<p class="mt-2">
							<a
								href={`tel:${office.phone.replace(/\s/g, '')}`}
								class="text-brand-gold font-semibold hover:underline"
								data-sanity={siteField(keyedArrayFieldPath('offices', office._key, 'phone') ?? 'offices')}
							>
								{office.phone}
							</a>
						</p>
					</div>
				))
			}
			<div>
				<h2 class="font-display text-xl font-semibold text-brand-navy mb-2" data-sanity={contactPageField('emailSectionHeading')}>{contactPage.emailSectionHeading}</h2>
				<a href={`mailto:${site.contactEmail}`} class="text-brand-gold font-semibold hover:underline break-all" data-sanity={siteField('contactEmail')}>
					{site.contactEmail}
				</a>
			</div>
		</div>
		<div class="space-y-6">
			{
				offices.map((office) =>
					office.mapEmbedUrl ? (
						<div class="rounded-xl overflow-hidden border border-slate-200 shadow-sm aspect-video">
							<iframe
								title={office.mapIframeTitle ?? `${office.label} office map`}
								class="w-full h-full min-h-[240px]"
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"
								src={office.mapEmbedUrl}
							/>
						</div>
					) : null,
				)
			}
		</div>
	</section>

	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-3xl mx-auto text-center mb-12">
			<h2 class="font-display text-3xl font-semibold text-brand-navy mb-8" data-sanity={contactPageField('contactFormSectionHeading')}>{contactPage.contactFormSectionHeading}</h2>
			<ContactForm
				idSuffix="contact"
			/>
		</div>
	</section>

	<section class="max-w-3xl mx-auto px-4 pb-20 pt-8">
		<h2 class="font-display text-2xl font-semibold text-brand-navy mb-4" data-sanity={contactPageField('internshipsHeading')}>{contactPage.internshipsHeading}</h2>
		<p class="text-slate-700 leading-relaxed mb-6 text-justify" data-sanity={contactPageField('internshipsBody')}>
			{contactPage.internshipsBody}
		</p>
		<a
			href={contactPage.internshipsCtaHref ?? '/jobs/internship'}
			class="inline-flex rounded-md bg-brand-gold px-6 py-3 font-semibold text-brand-navy hover:bg-brand-gold-light"
			data-sanity={contactPageField('internshipsCtaLabel')}
		>
			{contactPage.internshipsCtaLabel}
		</a>
	</section>
</BaseLayout>
