---
import ContactForm from '../components/ContactForm.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactFormSettingsQuery, contactPageQuery, siteSettingsCompactQuery } from '../lib/sanity/queries';
import type { ContactFormSettingsDoc, ContactPageDoc, SiteSettingsDoc } from '../lib/sanity/types';
import { sanityClient } from 'sanity:client';
import { mergeContactFormSettings, mergeContactPage, mergeSiteSettings } from '../lib/sanity/mergeContent';

const [siteRaw, contactPageRaw, contactFormRaw] = await Promise.all([
	sanityClient.fetch<Partial<SiteSettingsDoc> | null>(siteSettingsCompactQuery),
	sanityClient.fetch<Partial<ContactPageDoc> | null>(contactPageQuery),
	sanityClient.fetch<ContactFormSettingsDoc | null>(contactFormSettingsQuery),
]);

const site = mergeSiteSettings(siteRaw);
const contactPage = mergeContactPage(contactPageRaw);
const contactForm = mergeContactFormSettings(contactFormRaw);
const offices = site.offices;
---

<BaseLayout title={`Contact Us & Careers — ${site.siteTitle}`} description={site.siteDescription ?? ''}>
	<Hero title={contactPage.heroTitle ?? "Let's Connect"} subtitle={contactPage.heroSubtitle ?? undefined} variant="dark" />

	<section class="max-w-6xl mx-auto px-4 py-16 grid md:grid-cols-2 gap-12">
		<div class="space-y-8">
			{
				offices.map((office) => (
					<div>
						<h2 class="font-display text-xl font-semibold text-brand-navy mb-2">{office.label}</h2>
						<p class="text-slate-700">{office.street}</p>
						<p class="text-slate-700">{office.city}</p>
						<p class="mt-2">
							<a href={`tel:${office.phone.replace(/\s/g, '')}`} class="text-brand-gold font-semibold hover:underline">
								{office.phone}
							</a>
						</p>
					</div>
				))
			}
			<div>
				<h2 class="font-display text-xl font-semibold text-brand-navy mb-2">{contactPage.emailSectionHeading}</h2>
				<a href={`mailto:${site.contactEmail}`} class="text-brand-gold font-semibold hover:underline break-all">
					{site.contactEmail}
				</a>
			</div>
		</div>
		<div class="space-y-6">
			{
				offices.map((office) =>
					office.mapEmbedUrl ? (
						<div class="rounded-xl overflow-hidden border border-slate-200 shadow-sm aspect-video">
							<iframe
								title={office.mapIframeTitle ?? `${office.label} office map`}
								class="w-full h-full min-h-[240px]"
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"
								src={office.mapEmbedUrl}
							/>
						</div>
					) : null,
				)
			}
		</div>
	</section>

	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-3xl mx-auto text-center mb-12">
			<h2 class="font-display text-3xl font-semibold text-brand-navy mb-8">{contactPage.contactFormSectionHeading}</h2>
			<ContactForm idSuffix="contact" settings={contactForm} />
		</div>
	</section>

	<section class="max-w-3xl mx-auto px-4 pb-20">
		<h2 class="font-display text-2xl font-semibold text-brand-navy mb-4">{contactPage.internshipsHeading}</h2>
		<p class="text-slate-700 leading-relaxed mb-6">
			{contactPage.internshipsBody}
		</p>
		<a
			href={contactPage.internshipsCtaHref ?? '/jobs/internship'}
			class="inline-flex rounded-md bg-brand-gold px-6 py-3 font-semibold text-brand-navy hover:bg-brand-gold-light"
		>
			{contactPage.internshipsCtaLabel}
		</a>
	</section>
</BaseLayout>
