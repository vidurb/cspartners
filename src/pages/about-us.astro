---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import Hero from '../components/Hero.astro';
import PortableTextBody from '../components/PortableTextBody.astro';
import {
	aboutPageQuery,
	contactFormSettingsQuery,
	siteSettingsCompactQuery,
} from '../lib/sanity/queries';
import type { AboutPageDoc, ContactFormSettingsDoc, SiteSettingsDoc } from '../lib/sanity/types';
import { loadQuery } from '../lib/sanity/loadQuery';
import { keyedArrayFieldPath, singletonDataAttribute } from '../lib/sanity/dataAttributes';
import { mergeAboutPage, mergeContactFormSettings, mergeSiteSettings } from '../lib/sanity/mergeContent';

const [siteRaw, aboutRaw, contactFormRaw] = await Promise.all([
	loadQuery<Partial<SiteSettingsDoc> | null>(siteSettingsCompactQuery),
	loadQuery<Partial<AboutPageDoc> | null>(aboutPageQuery),
	loadQuery<ContactFormSettingsDoc | null>(contactFormSettingsQuery),
]);

const site = mergeSiteSettings(siteRaw);
const about = mergeAboutPage(aboutRaw);
const contactForm = mergeContactFormSettings(contactFormRaw);
const aboutId = about._id ?? 'aboutPage';
const contactFormId = contactForm._id ?? 'contactFormSettings';
const aboutField = (path: string) => singletonDataAttribute('aboutPage', path, aboutId);
const contactFormField = (path: string) => singletonDataAttribute('contactFormSettings', path, contactFormId);
const founderPhotos = [
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/02/51-image-1024x683.jpg',
		srcset:
			'https://cspartners.in/wp-content/uploads/2026/02/51-image-300x200.jpg 300w, https://cspartners.in/wp-content/uploads/2026/02/51-image-768x512.jpg 768w, https://cspartners.in/wp-content/uploads/2026/02/51-image-1024x683.jpg 1024w, https://cspartners.in/wp-content/uploads/2026/02/51-image-1536x1024.jpg 1536w, https://cspartners.in/wp-content/uploads/2026/02/51-image-2048x1365.jpg 2048w',
	},
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/03/9B1A8854-1024x683.jpg',
		srcset:
			'https://cspartners.in/wp-content/uploads/2026/03/9B1A8854-300x200.jpg 300w, https://cspartners.in/wp-content/uploads/2026/03/9B1A8854-768x512.jpg 768w, https://cspartners.in/wp-content/uploads/2026/03/9B1A8854-1024x683.jpg 1024w, https://cspartners.in/wp-content/uploads/2026/03/9B1A8854-1536x1024.jpg 1536w, https://cspartners.in/wp-content/uploads/2026/03/9B1A8854-2048x1365.jpg 2048w',
	},
	{
		src: 'https://cspartners.in/wp-content/uploads/2026/03/9B1A8893-1024x683.jpg',
		srcset:
			'https://cspartners.in/wp-content/uploads/2026/03/9B1A8893-300x200.jpg 300w, https://cspartners.in/wp-content/uploads/2026/03/9B1A8893-768x512.jpg 768w, https://cspartners.in/wp-content/uploads/2026/03/9B1A8893-1024x683.jpg 1024w, https://cspartners.in/wp-content/uploads/2026/03/9B1A8893-1536x1024.jpg 1536w, https://cspartners.in/wp-content/uploads/2026/03/9B1A8893-2048x1365.jpg 2048w',
	},
];
---

<BaseLayout title={`About Us — ${site.siteTitle}`} description={site.siteDescription ?? ''}>
	<Hero title="About Us" variant="dark" />
	<section class="max-w-6xl mx-auto px-4 pt-16">
		<div class="grid gap-6 md:grid-cols-3">
			{
				founderPhotos.map((photo) => (
					<div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
						<img
							src={photo.src}
							srcset={photo.srcset}
							sizes="(min-width: 768px) 33vw, 100vw"
							alt="C&S Partners founder portrait"
							class="h-full w-full object-cover"
							width="1024"
							height="683"
							loading="lazy"
						/>
					</div>
				))
			}
		</div>
	</section>

	<div class="max-w-3xl mx-auto px-4 py-16 space-y-10 text-slate-700 leading-relaxed text-lg">
		{
			about.sections?.map((section) => (
				<section>
					{section.heading && (
						<h2
							class="font-display text-2xl font-semibold text-brand-navy mb-4"
							data-sanity={aboutField(keyedArrayFieldPath('sections', section._key, 'heading') ?? 'sections')}
						>{section.heading}</h2>
					)}
					<PortableTextBody
						value={section.body}
						dataSanity={aboutField(keyedArrayFieldPath('sections', section._key, 'body') ?? 'sections')}
					/>
				</section>
			))
		}
		{
			about.practiceAreasCtaLabel && (
				<p class="mt-6 text-justify">
					<a
						href={about.practiceAreasCtaHref ?? '/practice-area'}
						class="font-semibold text-brand-gold hover:text-brand-gold-light"
						data-sanity={aboutField('practiceAreasCtaLabel')}
					>
						{about.practiceAreasCtaLabel}
					</a>
				</p>
			)
		}
	</div>

	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-3xl mx-auto text-center">
			<h2 class="font-display text-3xl font-semibold text-brand-navy mb-8" data-sanity={aboutField('contactSectionHeading')}>{about.contactSectionHeading}</h2>
			<ContactForm
				idSuffix="about"
				settings={contactForm}
				fieldDataSanity={{
					intro: contactFormField('intro'),
					nameLabel: contactFormField('nameLabel'),
					namePlaceholder: contactFormField('namePlaceholder'),
					mobileLabel: contactFormField('mobileLabel'),
					mobilePlaceholder: contactFormField('mobilePlaceholder'),
					emailLabel: contactFormField('emailLabel'),
					emailPlaceholder: contactFormField('emailPlaceholder'),
					messageLabel: contactFormField('messageLabel'),
					messagePlaceholder: contactFormField('messagePlaceholder'),
					submitLabel: contactFormField('submitLabel'),
					footnote: contactFormField('footnote'),
				}}
			/>
		</div>
	</section>
</BaseLayout>
