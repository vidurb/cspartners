---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import Hero from '../components/Hero.astro';
import PortableTextBody from '../components/PortableTextBody.astro';
import {
	aboutPageQuery,
	contactFormSettingsQuery,
	siteSettingsCompactQuery,
} from '../lib/sanity/queries';
import type { AboutPageDoc, ContactFormSettingsDoc, SiteSettingsDoc } from '../lib/sanity/types';
import { loadQuery } from '../lib/sanity/loadQuery';
import { mergeAboutPage, mergeContactFormSettings, mergeSiteSettings } from '../lib/sanity/mergeContent';

const [siteRaw, aboutRaw, contactFormRaw] = await Promise.all([
	loadQuery<Partial<SiteSettingsDoc> | null>(siteSettingsCompactQuery),
	loadQuery<Partial<AboutPageDoc> | null>(aboutPageQuery),
	loadQuery<ContactFormSettingsDoc | null>(contactFormSettingsQuery),
]);

const site = mergeSiteSettings(siteRaw);
const about = mergeAboutPage(aboutRaw);
const contactForm = mergeContactFormSettings(contactFormRaw);
---

<BaseLayout title={`About Us — ${site.siteTitle}`} description={site.siteDescription ?? ''}>
	<Hero title="About Us" variant="dark" />
	<div class="max-w-3xl mx-auto px-4 py-16 space-y-10 text-slate-700 leading-relaxed text-lg">
		{
			about.sections?.map((section) => (
				<section>
					{section.heading && (
						<h2 class="font-display text-2xl font-semibold text-brand-navy mb-4">{section.heading}</h2>
					)}
					<PortableTextBody value={section.body} />
				</section>
			))
		}
		{
			about.practiceAreasCtaLabel && (
				<p class="mt-6">
					<a
						href={about.practiceAreasCtaHref ?? '/practice-area'}
						class="font-semibold text-brand-gold hover:text-brand-gold-light"
					>
						{about.practiceAreasCtaLabel}
					</a>
				</p>
			)
		}
	</div>

	<section class="py-16 px-4 bg-brand-paper">
		<div class="max-w-3xl mx-auto text-center">
			<h2 class="font-display text-3xl font-semibold text-brand-navy mb-8">{about.contactSectionHeading}</h2>
			<ContactForm idSuffix="about" settings={contactForm} />
		</div>
	</section>
</BaseLayout>
