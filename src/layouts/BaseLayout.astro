---
import BaseHead from '../components/BaseHead.astro';
import BotIdInit from '../components/BotIdInit.astro';
import DisclaimerPopup from '../components/DisclaimerPopup.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { layoutSingletonsBundleQuery } from '../lib/sanity/queries';
import { loadQuery } from '../lib/sanity/loadQuery';
import { mergeLayoutSingletonsBundle } from '../lib/sanity/mergeContent';
import type { LayoutSingletonsBundle } from '../lib/sanity/types';
import { VisualEditing } from '@sanity/astro/visual-editing';
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	mainClass?: string;
}

const { title, description, image, mainClass = '' } = Astro.props;

const rawLayout = await loadQuery<LayoutSingletonsBundle>(layoutSingletonsBundleQuery);
const { site, disclaimer } = mergeLayoutSingletonsBundle(rawLayout);
const visualEditingEnabled = import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === 'true';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} siteTitle={site.siteTitle} />
	</head>
	<body class="min-h-screen flex flex-col bg-brand-cream text-slate-800">
		<BotIdInit />
		<DisclaimerPopup disclaimer={disclaimer} />
		<Header site={site} />
		<main class:list={['flex-1 w-full', mainClass]}>
			<slot />
		</main>
		<Footer site={site} />
		<VisualEditing enabled={visualEditingEnabled} zIndex={1000} />
	</body>
</html>
