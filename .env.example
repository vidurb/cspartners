# Public (exposed to browser / RSS) — defaults match repo if unset
PUBLIC_SANITY_PROJECT_ID=u1i19rrb
PUBLIC_SANITY_DATASET=production

# Enables Sanity Presentation overlays and draft queries when set to "true"
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=false
# Viewer token required when Visual Editing is enabled; never commit a real value
SANITY_API_READ_TOKEN=
# Frontend URL loaded by Sanity Studio Presentation in local/dev environments
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321

# Write token for `pnpm sanity:import` (Editor permissions; never commit real value)
SANITY_API_WRITE_TOKEN=

# Optional: Vercel deploy hook URL (documented for Sanity webhook; not read by app code)
VERCEL_DEPLOY_HOOK_URL=

# --- Contact form (Astro Action + Resend + Vercel BotID) ---
# Recipient for website contact submissions (server-only; not exposed to the client)
CONTACT_EMAIL_TO=
# Verified sender in Resend (e.g. "CS Partners <onboarding@resend.dev>" or your domain)
CONTACT_EMAIL_FROM=
# Resend API key (server-only)
RESEND_API_KEY=

# BotID on Vercel: enable "Secure Backend Access with OIDC" / federation token in project
# settings so serverless can call the BotID API. Local dev treats requests as human by default.
